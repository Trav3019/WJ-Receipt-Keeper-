# ── Supabase ──────────────────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# From: supabase.com → your project → Settings → Database → Connection string
# Use the "Transaction" mode URI (port 6543) for serverless/Vercel
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[password]@aws-0-ca-central-1.pooler.supabase.com:6543/postgres

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel Blob (for image uploads) ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=