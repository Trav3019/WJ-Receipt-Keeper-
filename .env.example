# ── Vercel Postgres ──────────────────────────────────────────────────────────
# Automatically populated when you add the Vercel Postgres integration.
# For local dev, copy from your Vercel project's Storage tab.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Automatically populated when you add the Vercel Blob integration.
BLOB_READ_WRITE_TOKEN=

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
